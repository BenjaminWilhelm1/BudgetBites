<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- LEGACY KEYS (kept so Styles.xaml compiles) -->
    <Color x:Key="Primary">#74B266</Color>
    <Color x:Key="PrimaryDark">#5E9752</Color>
    <Color x:Key="PrimaryDarkText">#F3F4F6</Color>
    <Color x:Key="Secondary">#232932</Color>
    <Color x:Key="SecondaryDarkText">#A1A8B3</Color>
    <Color x:Key="Tertiary">#A78BFA</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#A78BFA</Color>
    <Color x:Key="MidnightBlue">#A78BFA</Color>
    <Color x:Key="OffBlack">#111315</Color>

    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#A1A8B3</Color>
    <Color x:Key="Gray300">#7B8491</Color>
    <Color x:Key="Gray400">#586170</Color>
    <Color x:Key="Gray500">#7B8491</Color>
    <Color x:Key="Gray600">#2D3440</Color>
    <Color x:Key="Gray900">#1A1E22</Color>
    <Color x:Key="Gray950">#111315</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- DESIGN SYSTEM COLORS -->
    <Color x:Key="Bg">#111315</Color>
    <Color x:Key="Surface">#1A1E22</Color>
    <Color x:Key="Surface2">#232932</Color>
    <Color x:Key="BorderColor">#2D3440</Color>

    <Color x:Key="TextPrimary">#F3F4F6</Color>
    <Color x:Key="TextSecondary">#A1A8B3</Color>
    <Color x:Key="TextMuted">#7B8491</Color>

    <Color x:Key="Brand">#A78BFA</Color>
    <Color x:Key="PrimaryGreen">#74B266</Color>
    <Color x:Key="PrimaryPressed">#5E9752</Color>
    <Color x:Key="SecondaryAccent">#E6C58D</Color>
    <Color x:Key="AccentBlue">#6EA8DC</Color>

    <Color x:Key="SuccessTint">#1E2B22</Color>
    <Color x:Key="WarningTint">#2C2519</Color>
    <Color x:Key="InfoTint">#1C2630</Color>

</ResourceDictionary>