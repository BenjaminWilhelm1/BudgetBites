<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetBites.Pages.HomePage"
             Title="BudgetBites"
             BackgroundColor="{StaticResource Bg}">
    <ScrollView>
        <VerticalStackLayout
            Padding="40,20"
            Spacing="20">

            <VerticalStackLayout Spacing="4">
                <Label Text="Welcome to BudgetBites"
                       Style="{StaticResource PageTitleStyle}" />
                <Label Text="Track your groceries, pantry, and spending."
                       Style="{StaticResource PageSubtitleStyle}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="14">

                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <BoxView BackgroundColor="{StaticResource PrimaryGreen}"
                                 HeightRequest="3"
                                 CornerRadius="2"
                                 HorizontalOptions="Start"
                                 WidthRequest="32"
                                 Margin="0,0,0,8" />
                        <Label Text="Grocery items to buy"
                               Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding GroceryItemCount}"
                               Style="{StaticResource StatValueGreenStyle}" />
                        <Label Text="{Binding EstimatedGroceryTotal, StringFormat='Est: ${0:F2}'}"
                               Style="{StaticResource MetaStyle}"
                               Margin="0,2,0,0" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <BoxView BackgroundColor="{StaticResource SecondaryAccent}"
                                 HeightRequest="3"
                                 CornerRadius="2"
                                 HorizontalOptions="Start"
                                 WidthRequest="32"
                                 Margin="0,0,0,8" />
                        <Label Text="Pantry items"
                               Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding PantryItemCount}"
                               Style="{StaticResource StatValueOatStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        Padding="20,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <BoxView BackgroundColor="{StaticResource AccentBlue}"
                                 HeightRequest="3"
                                 CornerRadius="2"
                                 HorizontalOptions="Start"
                                 WidthRequest="32"
                                 Margin="0,0,0,8" />
                        <Label Text="Spent this month"
                               Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding SpentThisMonth, StringFormat='${0:F2}'}"
                               Style="{StaticResource StatValueBlueStyle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="6">
                <Label Text="Quick Actions"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,4,0,4" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Grocery List"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToGroceryCommand}" />
                    <Button Grid.Column="1" Text="Pantry"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToPantryCommand}" />
                    <Button Grid.Column="2" Text="Budget"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToBudgetCommand}" />
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>