<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetBites.Pages.HomePage"
             Title="BudgetBites">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Welcome to BudgetBites" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Track your groceries, pantry, and spending." FontSize="14" TextColor="Gray" HorizontalOptions="Center" />

            <Frame BackgroundColor="#E8F5E9" Padding="16" CornerRadius="12" BorderColor="Transparent">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Grocery items to buy" FontSize="13" TextColor="Gray" />
                    <Label Text="{Binding GroceryItemCount}" FontSize="28" FontAttributes="Bold" TextColor="#2E7D32" />
                    <Label Text="{Binding EstimatedGroceryTotal, StringFormat='Estimated: ${0:F2}'}" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#FFF3E0" Padding="16" CornerRadius="12" BorderColor="Transparent">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Pantry items" FontSize="13" TextColor="Gray" />
                    <Label Text="{Binding PantryItemCount}" FontSize="28" FontAttributes="Bold" TextColor="#E65100" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#E3F2FD" Padding="16" CornerRadius="12" BorderColor="Transparent">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Spent this month" FontSize="13" TextColor="Gray" />
                    <Label Text="{Binding SpentThisMonth, StringFormat='${0:F2}'}" FontSize="28" FontAttributes="Bold" TextColor="#1565C0" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="View Grocery List" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="10" HeightRequest="48" Command="{Binding GoToGroceryCommand}" />
            <Button Text="View Pantry" BackgroundColor="#FF9800" TextColor="White" CornerRadius="10" HeightRequest="48" Command="{Binding GoToPantryCommand}" />
            <Button Text="View Budget" BackgroundColor="#2196F3" TextColor="White" CornerRadius="10" HeightRequest="48" Command="{Binding GoToBudgetCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>