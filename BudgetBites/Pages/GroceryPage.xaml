<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BudgetBites.Models"
             xmlns:viewmodels="clr-namespace:BudgetBites.ViewModels"
             x:Class="BudgetBites.Pages.GroceryPage"
             Title="Grocery List"
             BackgroundColor="{StaticResource Bg}">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="40,20">

        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                Padding="18,14"
                Margin="0,0,0,12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <BoxView Grid.Column="0"
                         BackgroundColor="{StaticResource PrimaryGreen}"
                         WidthRequest="3"
                         CornerRadius="2"
                         VerticalOptions="Fill" />
                <Label Grid.Column="1"
                       Text="Estimated Total"
                       Style="{StaticResource CardLabelStyle}"
                       VerticalOptions="Center"
                       Margin="8,0,0,0" />
                <Label Grid.Column="2"
                       Text="{Binding EstimatedTotal, StringFormat='${0:F2}'}"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryGreen}"
                       VerticalOptions="Center" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20,40" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="No grocery items yet"
                           FontSize="16"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Tap '+ Add Item' to get started"
                           Style="{StaticResource MetaStyle}"
                           HorizontalTextAlignment="Center"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:GroceryItem">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="#C0392B"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:GroceryListViewModel}}, Path=DeleteItemCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeThickness="1"
                                Padding="14,10"
                                Margin="0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:GroceryListViewModel}}, Path=TogglePurchasedCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsPurchased, Mode=OneWay}"
                                          Color="{StaticResource PrimaryGreen}"
                                          VerticalOptions="Center"
                                          InputTransparent="True" />

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label FontSize="12" TextColor="{StaticResource TextMuted}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Category}" TextColor="{StaticResource TextMuted}" />
                                                <Span Text=" · " TextColor="{StaticResource TextMuted}" />
                                                <Span Text="{Binding Quantity}" TextColor="{StaticResource TextMuted}" />
                                                <Span Text=" × $" TextColor="{StaticResource TextMuted}" />
                                                <Span Text="{Binding UnitPrice, StringFormat='{0:F2}'}" TextColor="{StaticResource TextMuted}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="{Binding TotalPrice, StringFormat='${0:F2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryGreen}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Text="+ Add Item"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="0,12,0,0"
                Command="{Binding GoToAddItemCommand}" />
    </Grid>
</ContentPage>