<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BudgetBites.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BudgetBites"
    Shell.FlyoutBehavior="Disabled"
    Title="BudgetBites">

	<TabBar>

		<ShellContent Title="Home"
					  ContentTemplate="{DataTemplate local:HomePage}" />

		<ShellContent Title="Grocery"
					  ContentTemplate="{DataTemplate local:GroceryPage}" />

		<ShellContent Title="Pantry"
					  ContentTemplate="{DataTemplate local:PantryPage}" />

		<ShellContent Title="Budget"
					  ContentTemplate="{DataTemplate local:BudgetPage}" />

	</TabBar>

</Shell>
