<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:BudgetBites.Pages"
       x:Class="BudgetBites.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="True"
       Shell.BackgroundColor="{StaticResource Bg}"
       Shell.TitleColor="{StaticResource Brand}"
       Shell.ForegroundColor="{StaticResource TextPrimary}"
       Shell.TabBarBackgroundColor="{StaticResource Surface}"
       Shell.TabBarTitleColor="{StaticResource PrimaryGreen}"
       Shell.TabBarUnselectedColor="{StaticResource TextMuted}"
       Title="BudgetBites">
    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate pages:HomePage}" Route="home" />
        <ShellContent Title="Grocery" ContentTemplate="{DataTemplate pages:GroceryPage}" Route="grocery" />
        <ShellContent Title="Pantry" ContentTemplate="{DataTemplate pages:PantryPage}" Route="pantry" />
        <ShellContent Title="Budget" ContentTemplate="{DataTemplate pages:BudgetPage}" Route="budget" />
    </TabBar>
</Shell>